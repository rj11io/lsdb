{
  "name": "@rj11io/lsdb",
  "version": "1.0.0",
  "description": "LocalStorage database service",
  "homepage": "https://github.com/rj11io/lsdb#readme",
  "bugs": {
    "url": "https://github.com/rj11io/lsdb/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rj11io/lsdb.git"
  },
  "license": "Apache-2.0",
  "author": "rj11io",
  "private": false,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "npm run build && node -e \"require('./dist/index.js')\"",
    "test": "npm run lint",
    "prepack": "npm run build",
    "semantic-release": "semantic-release",
    "publish-public-local": "node ./.agents/skills/npm-publishing/scripts/publish-with-local-token.cjs"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "11.0.6",
    "@semantic-release/npm": "12.0.2",
    "@semantic-release/release-notes-generator": "14.1.0",
    "semantic-release": "24.2.7",
    "typescript": "5.8.3"
  },
  "overrides": {
    "lodash-es": "4.17.21"
  }
}
